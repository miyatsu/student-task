{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "type": "module",
  "scripts": {
    "preinstall": "node scripts/check-node-version.mjs",
    "postinstall": "node scripts/bootstrap-local-ocr.mjs",
    "dev": "tsx server.ts",
    "build": "vite build",
    "start": "node server.ts",
    "preview": "node scripts/run-preview-server.mjs",
    "preview:static": "vite preview",
    "setup:ocr": "node scripts/bootstrap-local-ocr.mjs",
    "clean": "rm -rf dist",
    "test": "npm run test:logic && npm run test:app",
    "test:logic": "node --import tsx --test src/features/files/file-utils.test.ts",
    "test:app": "vitest run",
    "test:ui": "npm run test:app",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@tensorflow/tfjs": "^4.11.0",
    "@types/compression": "^1.8.1",
    "@vitejs/plugin-react": "^5.0.4",
    "browser-image-compression": "^2.0.2",
    "compression": "^1.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "html2pdf.js": "^0.14.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "mupdf": "^1.27.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "upscaler": "^1.0.0",
    "vite": "^6.2.0",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.25",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/word-extractor": "^1.0.6",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.7"
  }
}
