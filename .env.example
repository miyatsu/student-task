# Get a free standalone Gemini API key from:
# https://aistudio.google.com/app/apikey
#
# Local development:
#   1. Copy this file to .env
#   2. Fill in your real Gemini API key
#   3. Run npm run dev
#
# Cloud deployment (Cloud Run / VPS / container):
#   Configure GEMINI_API_KEY in the platform environment variables.
#   After build, server.ts reads it at runtime when npm run start launches.
GEMINI_API_KEY=your_actual_key_here
